{
    "name": "unified/sso-client",
    "description": "OAuth2 SSO client package for Unified Solutions applications",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Unified\\SsoClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Unified\\SsoClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Unified\\SsoClient\\SsoServiceProvider"
            ],
            "aliases": {
                "Metrics": "Unified\\SsoClient\\Metrics\\Facades\\Metrics"
            }
        }
    },
    "minimum-stability": "stable"
}
